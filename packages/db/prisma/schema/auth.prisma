model User {
  id                        String                     @id @default(cuid(2))
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @default(now()) @updatedAt
  name                      String
  email                     String
  slug                      String                     @unique @default(cuid(2))
  emailVerified             Boolean                    @default(false)
  image                     String?
  // Better-Auth's admin plugin stores role as a string and supports arbitrary
  // custom roles plus comma-separated multi-role values. Do not narrow this to
  // a Prisma enum unless you also drop those Better-Auth capabilities.
  role                      String                     @default("user")
  // Preferred UI locale (BCP 47 tag). Synced into the i18n detection chain
  // ahead of localStorage / navigator so a signed-in user's choice follows
  // them across devices. Stored as String (not enum) because the supported-
  // locale set evolves outside the schema; new locales are added in
  // apps/web/src/i18n/config.ts without a Prisma migration.
  locale                    String                     @default("en-US")
  banned                    Boolean?
  banReason                 String?
  banExpires                DateTime?
  twoFactorEnabled          Boolean?
  operationalAlerts         Boolean                    @default(true)
  sessions                  Session[]
  accounts                  Account[]
  twoFactors                TwoFactor[]
  deviceCodes               DeviceCode[]
  cliDevices                CliDevice[]                @relation("CliDeviceOwner")
  cliTokens                 CliToken[]                 @relation("CliTokenOwner")
  cliDeviceCredentials      CliDeviceCredential[]      @relation("CliDeviceCredentialOwner")
  endpoints                 Endpoint[]                 @relation("EndpointOwner")
  discoveredModels          DiscoveredModel[]          @relation("DiscoveredModelOwner")
  modelPools                ModelPool[]                @relation("ModelPoolOwner")
  ownedPoolGrants           PoolGrant[]                @relation("PoolGrantOwner")
  receivedPoolGrants        PoolGrant[]                @relation("PoolGrantGrantee")
  modelApiTokens            ModelApiToken[]            @relation("ModelApiTokenOwner")
  responseStickinessRecords ResponseStickinessRecord[] @relation("ResponseStickinessOwner")
  relayRequests             RelayRequest[]             @relation("RelayRequestOwner")
  mediaAssets               MediaAsset[]               @relation("MediaAssetOwner")

  @@unique([email])
  @@index([slug])
  @@index([role])
  @@map("user")
}

model Session {
  id                   String   @id @default(cuid(2))
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  expiresAt            DateTime
  token                String
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid(2))
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid(2))
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}

model TwoFactor {
  id          String   @id @default(cuid(2))
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  secret      String
  backupCodes String
  verified    Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("two_factor")
}

model AppSetting {
  // `key` is the natural primary key — every read/write looks rows up by it,
  // so a separate cuid `id` would be dead weight. Deliberately deviates from
  // the repo's "every model has an id" rule for this single-column lookup table.
  key       String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  value     String

  @@map("app_setting")
}

model DeviceCode {
  id              String    @id @default(cuid(2))
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  deviceCode      String    @unique
  userCode        String    @unique
  userId          String?
  expiresAt       DateTime
  status          String
  lastPolledAt    DateTime?
  pollingInterval Int?
  clientId        String?
  scope           String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("device_code")
}
