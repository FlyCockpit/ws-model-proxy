# --- Web app (build-time, public) ------------------------------------------
# BUILD-TIME client vars — inlined into the browser bundle. Never put a secret here.

# Used in the app shell title/header.
# VITE_APP_NAME=WS Model Proxy

# API origin. Defaults to window.location.origin at runtime — leave unset
# for the portless/Vite proxy flow.
# VITE_SERVER_URL=http://localhost:3000

# Raw dev-server knobs. Leave unset with portless.
# VITE_DEV_PORT=3001
# VITE_DEV_SERVER_URL=http://localhost:3000
