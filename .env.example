# Copy to .env and fill in local values: cp .env.example .env
# Do not commit real secrets.

DATABASE_URL=postgresql://postgres:password@localhost:5432/ws-model-proxy

# Public web app display name.
VITE_APP_NAME=WS Model Proxy

# Optional raw server port. Portless injects PORT during `pnpm dev`.
# SERVER_PORT=3000

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://ws-model-proxy.localhost

# Set only for split-origin deployments.
# CORS_ORIGIN=https://ws-model-proxy.localhost

# Disabled by default after the first-user bootstrap. The first signup on an
# empty instance is allowed and becomes admin; later public signup requires this.
# SIGNUP_ENABLED=true

# Optional SMTP. Email/password auth works without it. Password reset and
# email-based 2FA delivery require it.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Rate limiting. Defaults are built into packages/env.
# RATE_LIMIT_RPC_POINTS=100
# RATE_LIMIT_RPC_DURATION=60
# RATE_LIMIT_AUTH_POINTS=10
# RATE_LIMIT_AUTH_DURATION=60
# RATE_LIMIT_AUTH_BLOCK_DURATION=900
# RATE_LIMIT_SIGNUP_POINTS=3
# RATE_LIMIT_SIGNUP_DURATION=3600
# RATE_LIMIT_SIGNUP_BLOCK_DURATION=3600
# TRUST_PROXY_HOPS=1

# Optional, only used by the i18n bundle translation script.
# TRANSLATION_PROVIDER=openrouter
# TRANSLATION_MODEL=anthropic/claude-haiku-4-5
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
